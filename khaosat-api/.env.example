ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-before-production
ALLOWED_ORIGINS=http://localhost:5173
# Render persistent disk, ví dụ: /var/data/survey.db
# DATABASE_PATH=/var/data/survey.db
DATA_BACKEND=sqlite
SESSION_CREATE_RATE_LIMIT_PER_MINUTE=60
ANALYTICS_SESSION_PAGE_SIZE=500
# JSONL_BACKUP_PATH=/var/data/backups/survey-events.jsonl
FIRESTORE_TIMEOUT_SECONDS=8

# Firebase Admin (để dành cho giai đoạn chuyển dữ liệu).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# Đặt file credential ngoài Git và trỏ đường dẫn tại đây.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json
# Render: có thể dán nguyên service-account JSON vào biến bí mật này thay cho file.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Tùy chọn: mặc định backend đọc hai file trong ../docs.
# SURVEY_WORKBOOK=/absolute/path/to/BoCauHoi.xlsx
# CRITERIA_WORKBOOK=/absolute/path/to/BỘ TIÊU CHÍ.xlsx
